# Copy this file to ".streamlit/secrets.toml" for local testing
# (that real file is git-ignored and must never be committed).
#
# On Streamlit Community Cloud, you don't create this file at all —
# instead you paste these same three lines into the app's
# Settings -> Secrets box in the web dashboard. See README.md for the
# full step-by-step.

GEMINI_API_KEY = "paste-your-gemini-api-key-here"
TURSO_DATABASE_URL = "libsql://your-database-name.turso.io"
TURSO_AUTH_TOKEN = "paste-your-turso-auth-token-here"
